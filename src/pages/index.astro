---
import HeadSEO from "@/components/HeadSEO.astro";
import "@/styles/global.css";
import "@fontsource-variable/inter";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";

import HeroBlock from "@/components/home/HeroBlock.astro";
import MissionBlock from "@/components/home/MissionBlock.astro";
import CtaBlock from "@/components/home/CtaBlock.astro";
import InvestmentBlock from "@/components/home/InvestmentBlock.astro";
import FeatureGridBlock from "@/components/home/FeatureGridBlock.astro";
import FinalCtaBlock from "@/components/home/FinalCtaBlock.astro";

const reader = createReader(process.cwd(), keystaticConfig);
const home = await reader.singletons.home.read();

const pageTitle = home?.seoTitle ?? "Jordi Rivero - AI CTO & Inversor";
const metaDescription =
  home?.seoDescription ??
  "AI CTO en LeadTech. Inversor y Estratega Técnico con background en sistemas de alto rendimiento, Telco y Social Media.";

const blocks = home?.blocks ?? [];
---

<html lang="es" class="scroll-smooth">
  <head>
    <HeadSEO title={pageTitle} description={metaDescription} author="Jordi Rivero" />
  </head>

  <body class="bg-black text-zinc-100 font-sans antialiased min-h-screen">
    <div class="max-w-4xl mx-auto border-x border-zinc-800 min-h-screen flex flex-col uppercase">
      {blocks.map((block) => {
        switch (block.discriminant) {
          case "hero":
            return <HeroBlock {...block.value} />;
          case "mission":
            return <MissionBlock {...block.value} />;
          case "cta":
            return <CtaBlock {...block.value} />;
          case "investment":
            return <InvestmentBlock {...block.value} />;
          case "featureGrid":
            return <FeatureGridBlock items={block.value.items} />;
          case "finalCta":
            return <FinalCtaBlock {...block.value} />;
        }
      })}

      <footer class="p-8 border-t border-zinc-800 bg-zinc-950 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-4 text-[10px] font-mono text-zinc-600 uppercase tracking-[0.3em]">
          <div class="w-2 h-2 bg-emerald-500 animate-pulse"></div>
          <span>© JRIVERO.NET</span>
          <span>/</span>
          <span>OP: TECHNICAL_STRATEGY</span>
        </div>
        <div class="flex gap-8">
          <a
            href="https://x.com/jrivero"
            class="text-zinc-400 hover:text-brand font-mono text-[10px] uppercase tracking-widest underline underline-offset-4 decoration-zinc-800"
            >Twitter Protocol</a
          >
          <a
            href="https://leadtech.com?utm_source=jrivero&utm_medium=link&utm_id=cto"
            class="text-zinc-400 hover:text-brand font-mono text-[10px] uppercase tracking-widest underline underline-offset-4 decoration-zinc-800"
            >Leadtech</a
          >
          <script
            defer
            src="https://eu.umami.is/script.js"
            data-website-id="033be64a-5f35-4177-8255-50707ce7f7d3"></script>
        </div>
      </footer>
    </div>

    <div class="fixed inset-0 pointer-events-none border-20 border-black/10 z-50"></div>
    <div class="fixed top-4 left-4 font-mono text-[8px] text-zinc-800 uppercase tracking-[0.4em] z-50 mix-blend-difference pointer-events-none">
      30Y_SYSTEM_HISTORY // LEVEL: EXPERT // STATUS: INNOVATING
    </div>
    <div class="fixed bottom-4 right-4 font-mono text-[8px] text-zinc-600 uppercase tracking-[0.4em] z-50 hidden md:block pointer-events-none">
      AI_AUGMENTED_WORKFLOW // LATENCY: 14MS // STACK: ASTRO+TAILWIND4+KEYSTATIC
    </div>
    <style>
      body {
        font-family: "Inter Variable", sans-serif;
      }
    </style>
  </body>
</html>
